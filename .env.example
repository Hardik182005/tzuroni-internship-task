# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b:free

# Apify Configuration
APIFY_TOKEN=your_apify_token_here
# Actor used for weather news/social scraping (official Apify actor by default)
APIFY_NEWS_ACTOR=apify/rag-web-browser
APIFY_MAX_RESULTS=3

# Groq Configuration (optional fast free-tier fallback provider, used only if OpenRouter is rate-limited)
GROQ_API_KEYS=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Database Configuration
DATABASE_URL=sqlite:///./weather_trading.db

# Telegram Notification Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Portfolio Configuration
INITIAL_BALANCE=10000.0
FRACTIONAL_KELLY=0.5
MAX_DAILY_LOSS_PCT=0.05
MAX_EXPOSURE_PCT=0.20
MAX_TOTAL_EXPOSURE_PCT=0.80

# Trading Settings
TRADING_CITIES=New York,London,Mumbai,Tokyo,Sydney,Berlin,Paris,Singapore,Toronto,Dubai,Delhi,Hong Kong,Los Angeles,Chicago,Rome,Amsterdam,Madrid,Melbourne,Seoul,Bangkok
RUN_INTERVAL_SECONDS=3600
SIMULATE_MARKETS_IF_EMPTY=True
